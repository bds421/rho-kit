{
  "title": "rho-kit / Redis",
  "uid": "rhokit-redis",
  "tags": ["rho-kit", "redis"],
  "schemaVersion": 38,
  "timezone": "",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(redis_command_duration_seconds_count, namespace)",
        "refresh": 2
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(redis_command_duration_seconds_count{namespace=\"$namespace\"}, service)",
        "refresh": 2
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(redis_command_duration_seconds_count{namespace=\"$namespace\", service=\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Command rate (cmd/s) by command",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (command) (rate(redis_command_duration_seconds_count{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{command}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Command error rate (err/s) by command",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (command) (rate(redis_command_errors_total{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{command}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Command latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(redis_command_duration_seconds_bucket{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(redis_command_duration_seconds_bucket{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(redis_command_duration_seconds_bucket{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Connection healthy (1=ok)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "redis_connection_healthy{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "title": "Pool: total / idle / stale connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (instance) (redis_pool_total_conns{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} total"
        },
        {
          "expr": "sum by (instance) (redis_pool_idle_conns{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} idle"
        },
        {
          "expr": "sum by (instance) (redis_pool_stale_conns{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} stale"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "Pool: hits / misses / timeouts (snapshot)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (instance) (redis_pool_hits{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} hits"
        },
        {
          "expr": "sum by (instance) (redis_pool_misses{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} misses"
        },
        {
          "expr": "sum by (instance) (redis_pool_timeouts{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"})",
          "legendFormat": "{{instance}} timeouts"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "title": "Reconnects (attempts vs successes, /s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (instance) (rate(redis_reconnect_attempts_total{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{instance}} attempts"
        },
        {
          "expr": "sum by (instance) (rate(redis_reconnect_successes_total{namespace=\"$namespace\", service=\"$service\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{instance}} successes"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 }
    }
  ]
}
