{
  "title": "rho-kit / Leader election",
  "uid": "rhokit-leaderelection",
  "tags": ["rho-kit", "leaderelection", "coordination"],
  "schemaVersion": 38,
  "timezone": "",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(leaderelection_callback_drain_seconds_bucket, namespace)",
        "refresh": 2
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(leaderelection_callback_drain_seconds_bucket{namespace=\"$namespace\"}, service)",
        "refresh": 2
      },
      {
        "name": "backend",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(leaderelection_callback_drain_seconds_bucket{namespace=\"$namespace\", service=\"$service\"}, backend)",
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2
      },
      {
        "name": "target",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(leaderelection_callback_drain_seconds_bucket{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\"}, target)",
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Callback drain p50 / p95 / p99 (seconds, terminal drained observations)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, backend, target) (rate(leaderelection_callback_drain_seconds_bucket{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\", target=~\"$target\", state=\"drained\"}[5m])))",
          "legendFormat": "{{backend}} {{target}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, backend, target) (rate(leaderelection_callback_drain_seconds_bucket{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\", target=~\"$target\", state=\"drained\"}[5m])))",
          "legendFormat": "{{backend}} {{target}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, backend, target) (rate(leaderelection_callback_drain_seconds_bucket{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\", target=~\"$target\", state=\"drained\"}[5m])))",
          "legendFormat": "{{backend}} {{target}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Drain warn ticks per minute (long-running OnAcquired)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "60 * rate(leaderelection_callback_drain_warn_total{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\", target=~\"$target\"}[5m])",
          "legendFormat": "{{backend}} {{target}} warns/min"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Drain timeouts (terminal — orchestrator must restart process)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (backend, target) (increase(leaderelection_callback_drain_seconds_count{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\", target=~\"$target\", state=\"timeout\"}[10m]))",
          "legendFormat": "{{backend}} {{target}} timeouts (10m)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Pending snapshots (in-flight drains as they tick)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(leaderelection_callback_drain_seconds_count{namespace=\"$namespace\", service=\"$service\", backend=~\"$backend\", target=~\"$target\", state=\"pending\"}[5m])",
          "legendFormat": "{{backend}} {{target}} pending obs/s"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
