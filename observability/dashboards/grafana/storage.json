{
  "title": "rho-kit / Storage providers overview",
  "uid": "rhokit-storage",
  "tags": ["rho-kit", "storage"],
  "schemaVersion": 38,
  "timezone": "",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_duration_seconds_count\"}, namespace)",
        "refresh": 2
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_duration_seconds_count\", namespace=\"$namespace\"}, service)",
        "refresh": 2
      },
      {
        "name": "storage_instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_duration_seconds_count\", namespace=\"$namespace\", service=\"$service\"}, storage_instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Operation rate (op/s) by provider and operation",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (__name__, operation) (rate({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_duration_seconds_count\", namespace=\"$namespace\", service=\"$service\", storage_instance=~\"$storage_instance\"}[5m]))",
          "legendFormat": "{{__name__}} {{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Error rate (err/s) by provider and operation",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (__name__, operation) (rate({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_errors_total\", namespace=\"$namespace\", service=\"$service\", storage_instance=~\"$storage_instance\"}[5m]))",
          "legendFormat": "{{__name__}} {{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Latency p95 (s) by provider and operation",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (__name__, operation, le) (rate({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_duration_seconds_bucket\", namespace=\"$namespace\", service=\"$service\", storage_instance=~\"$storage_instance\"}[5m])))",
          "legendFormat": "{{__name__}} {{operation}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Latency p99 (s) by provider and operation",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (__name__, operation, le) (rate({__name__=~\"storage_(s3|gcs|azure|sftp)_operation_duration_seconds_bucket\", namespace=\"$namespace\", service=\"$service\", storage_instance=~\"$storage_instance\"}[5m])))",
          "legendFormat": "{{__name__}} {{operation}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "title": "SFTP connection healthy (1=ok)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "storage_sftp_connection_healthy{namespace=\"$namespace\", service=\"$service\", storage_instance=~\"$storage_instance\"}",
          "legendFormat": "{{storage_instance}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "Provider dashboards",
      "type": "text",
      "options": {
        "mode": "markdown",
        "content": "- [S3](/d/rhokit-storage-s3)\n- [GCS](/d/rhokit-storage-gcs)\n- [Azure Blob Storage](/d/rhokit-storage-azure)\n- [SFTP](/d/rhokit-storage-sftp)"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
