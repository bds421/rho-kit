{
  "title": "rho-kit / Storage / GCS",
  "uid": "rhokit-storage-gcs",
  "tags": ["rho-kit", "storage", "gcs"],
  "schemaVersion": 38,
  "timezone": "",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(storage_gcs_operation_duration_seconds_count, namespace)",
        "refresh": 2
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(storage_gcs_operation_duration_seconds_count{namespace=\"$namespace\"}, service)",
        "refresh": 2
      },
      {
        "name": "storage_instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(storage_gcs_operation_duration_seconds_count{namespace=\"$namespace\", service=\"$service\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Operation rate (op/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (operation) (rate(storage_gcs_operation_duration_seconds_count{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Error rate (err/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (operation) (rate(storage_gcs_operation_errors_total{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m]))",
          "legendFormat": "{{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Error ratio",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (operation) (rate(storage_gcs_operation_errors_total{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m])) / clamp_min(sum by (operation) (rate(storage_gcs_operation_duration_seconds_count{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m])), 0.0001)",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (operation, le) (rate(storage_gcs_operation_duration_seconds_bucket{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m])))",
          "legendFormat": "{{operation}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(storage_gcs_operation_duration_seconds_bucket{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m])))",
          "legendFormat": "{{operation}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (operation, le) (rate(storage_gcs_operation_duration_seconds_bucket{namespace=\"$namespace\", service=\"$service\", instance=~\"$storage_instance\"}[5m])))",
          "legendFormat": "{{operation}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
