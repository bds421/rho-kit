package app

import (
	"context"
	"encoding/json"
	"errors"
	"fmt"
	_ "embed"

	kitamqp "github.com/bds421/rho-kit/app/amqp/v2"
	kitapp "github.com/bds421/rho-kit/app/v2"
	"github.com/bds421/rho-kit/infra/messaging/amqpbackend/v2"
	outboxpostgres "github.com/bds421/rho-kit/infra/outbox/postgres/v2"
	"github.com/bds421/rho-kit/infra/sqldb/pgx/v2"
	"github.com/bds421/rho-kit/infra/v2/messaging"
	"github.com/bds421/rho-kit/infra/v2/outbox"
	"github.com/bds421/rho-kit/observability/v2/auditlog"
)

//go:embed schemas/command-processed.schema.json
var commandProcessedSchema []byte

// startProductionConsumer is the explicit at-least-once boundary generated by
// the production profile. Replace the SQL and event names with domain logic;
// retain the inbox callback shape so receipts, local mutations, and outbox
// entries remain one transaction.
func startProductionConsumer(infra kitapp.Infrastructure, pool *pgx.Pool, audit *auditlog.Logger) {
	if pool == nil {
		panic("production profile: postgres pool missing")
	}
	conn, ok := kitamqp.Connection(infra).(*amqpbackend.Connection)
	if !ok || conn == nil {
		panic("production profile: AMQP connection missing")
	}
	publisher := kitamqp.Publisher(infra)
	consumer := kitamqp.Consumer(infra)
	if publisher == nil || consumer == nil {
		panic("production profile: AMQP publisher or consumer missing")
	}
	binding, err := amqpbackend.DeclareAll(conn, messaging.BindingSpec{
		Exchange: "{{.ServiceName}}.commands", ExchangeType: messaging.ExchangeDirect,
		ConsumerGroup: "{{.ServiceName}}.commands.v1", RoutingKey: "command.received",
	})
	if err != nil || len(binding) != 1 {
		panic(fmt.Sprintf("production profile: declare command topology: %v", err))
	}
	if err := amqpbackend.DeclareExchanges(conn, messaging.ExchangeSpec{
		Exchange: "{{.ServiceName}}.events", ExchangeType: messaging.ExchangeTopic,
	}); err != nil {
		panic(fmt.Sprintf("production profile: declare event exchange: %v", err))
	}

	inbox := outboxpostgres.NewInbox(pool.Pool())
	store := outboxpostgres.New(pool.Pool())
	writer := outbox.NewWriter(store, outboxpostgres.RequireTx)
	schemas := messaging.NewInMemorySchemaRegistry()
	if err := schemas.Register("command.processed", 1, commandProcessedSchema); err != nil {
		panic(fmt.Sprintf("production profile: register event contract: %v", err))
	}
	infra.AddHealthCheck(inbox.HealthCheck())
	relay := outbox.NewRelay(store, outbox.NewMessagingPublisher(publisher), infra.Logger)
	infra.Background("outbox-relay", relay.Start)
	infra.Background("command-consumer", func(ctx context.Context) error {
		err := consumer.Consume(ctx, binding[0], func(handlerCtx context.Context, d messaging.Delivery) error {
			result, err := inbox.Process(handlerCtx, "{{.ServiceName}}.commands.v1", d.Message.ID, func(txCtx context.Context) error {
				tx, ok := outboxpostgres.TxFromContext(txCtx)
				if !ok {
					return errors.New("production profile: inbox transaction missing")
				}
				if _, err := tx.Exec(txCtx, `INSERT INTO processed_commands (message_id) VALUES ($1)`, d.Message.ID); err != nil {
					return err
				}
				payload, err := json.Marshal(struct {
					ID string `json:"id"`
				}{ID: d.Message.ID})
				if err != nil {
					return fmt.Errorf("production profile: encode outgoing event: %w", err)
				}
				outgoing := messaging.Message{
					ID: d.Message.ID + ".processed", Type: "command.processed",
					SchemaVersion: 1, Payload: payload,
				}
				if err := schemas.ValidateMessage(outgoing); err != nil {
					return fmt.Errorf("production profile: validate outgoing event: %w", err)
				}
				return writer.Write(txCtx, outbox.WriteParams{
					Topic: "{{.ServiceName}}.events", RoutingKey: "command.processed",
					MessageID: outgoing.ID, MessageType: outgoing.Type,
					SchemaVersion: outgoing.SchemaVersion, Payload: outgoing.Payload,
				})
			})
			if err == nil && !result.Duplicate {
				if auditErr := audit.LogE(handlerCtx, auditlog.Event{
					Actor: "system", Action: "command.processed", Resource: "commands/" + d.Message.ID,
					Status: auditlog.StatusSuccess,
				}); auditErr != nil {
					infra.Logger.ErrorContext(handlerCtx, "production profile: audit committed command", "error", auditErr)
				}
			}
			return err // non-nil means no ACK; AMQP retry/DLQ remains active.
		})
		if errors.Is(err, context.Canceled) {
			return nil
		}
		return err
	})
}
