// Package app wires the {{.ServiceName}} service. Add new dependencies
// here so kit-doctor can scan a single, predictable file.
package app

import (
{{- if .MCP}}
	"context"
{{- end}}
{{- if .Tenant}}
	"fmt"
{{- end}}
	"log/slog"
	"net/http"
	"time"

	kitratelimit "github.com/bds421/rho-kit/app/ratelimit/v2"
{{- if .Tenant}}
	kitredisadapter "github.com/bds421/rho-kit/app/redis/v2"
	kittenant "github.com/bds421/rho-kit/app/tenant/v2"
{{- end}}
	kitapp "github.com/bds421/rho-kit/app/v2"
{{- if .Tenant}}
	coretenant "github.com/bds421/rho-kit/core/v2/tenant"
	rediscache "github.com/bds421/rho-kit/data/cache/rediscache/v2"
	redisstore "github.com/bds421/rho-kit/data/idempotency/redisstore/v2"
	sharedcache "github.com/bds421/rho-kit/data/v2/cache"
	tenantcache "github.com/bds421/rho-kit/data/v2/cache/tenant"
	sharedidempotency "github.com/bds421/rho-kit/data/v2/idempotency"
	tenantidempotency "github.com/bds421/rho-kit/data/v2/idempotency/tenant"
	httpidempotency "github.com/bds421/rho-kit/httpx/v2/middleware/idempotency"
	httpxtenant "github.com/bds421/rho-kit/httpx/v2/middleware/tenant"
	kitredis "github.com/bds421/rho-kit/infra/redis/v2"
{{- end}}
{{- if .Postgres}}

	"github.com/bds421/rho-kit/core/v2/config"
{{- end}}
{{- if .MCP}}

	"github.com/bds421/rho-kit/httpx/v2/mcp"
{{- end}}
{{- if .Postgres}}

	kitpostgres "github.com/bds421/rho-kit/app/postgres/v2"
	pgxbackend "github.com/bds421/rho-kit/infra/sqldb/pgx/v2"

	"{{.ModulePath}}/db/migrations"
{{- end}}
)

{{- if .MCP}}

// EchoIn is the input for the sample MCP tool. Replace with your
// service's own tool inputs — the validate:"required" tag is
// honoured by mcp.Register, so missing fields surface as -32602
// Invalid params at the JSON-RPC layer.
type EchoIn struct {
	Message string `json:"message" validate:"required" desc:"Text to echo back."`
}

// EchoOut is the response for the sample MCP tool.
type EchoOut struct {
	Echoed string `json:"echoed"`
}

// echo is the sample MCP handler. It demonstrates the typed
// signature mcp.Register expects: (ctx, in) -> (out, err).
func echo(_ context.Context, in EchoIn) (EchoOut, error) {
	return EchoOut{Echoed: in.Message}, nil
}

// newMCPServer builds the kit's MCP server with one sample tool
// registered. Production deployments wire WithActionLogger(...) and
// WithActorExtractor(...) so each call writes a tenant-scoped audit
// row.
func newMCPServer() *mcp.Server {
	srv := mcp.NewServer()
	if err := mcp.Register[EchoIn, EchoOut](srv, "echo", echo,
		mcp.WithToolDescription("Echo the input message back to the caller."),
	); err != nil {
		// Registration only fails on programming errors (cyclic
		// schema, duplicate name, empty name). Panic at startup so
		// the bug is impossible to ignore.
		panic("mcp register echo: " + err.Error())
	}
	return srv
}
{{- end}}
{{- if .Tenant}}

type tenantResources struct {
	Cache       sharedcache.Cache
	Idempotency sharedidempotency.Store
}

func newTenantResources(redis *kitredis.Connection) (tenantResources, error) {
	if redis == nil {
		return tenantResources{}, fmt.Errorf("tenant resources require Redis")
	}
	baseCache, err := rediscache.NewCache(redis.Client(), "{{.ServiceName}}-cache")
	if err != nil {
		return tenantResources{}, err
	}
	return tenantResources{
		Cache: tenantcache.Wrap(baseCache),
		Idempotency: tenantidempotency.Wrap(redisstore.New(
			redis.Client(),
			redisstore.WithKeyPrefix("{{.ServiceName}}:idempotency:"),
		)),
	}, nil
}

func tenantIDForIdempotency(r *http.Request) string {
	// Replace this with the authenticated subject once JWT/PASETO auth is
	// wired. Until then, tenant ID is the narrowest identity the scaffold has.
	id, ok := coretenant.FromContext(r.Context())
	if !ok {
		return ""
	}
	return id.String()
}
{{- end}}

// Run wires the service via [app.Builder] and blocks until the
// service exits. The Builder installs the kit's production-safety
// validator at startup (TLS required, JWT issuer + audience required,
// internal port loopback-only, no weak postgres sslmode); each check
// has a documented WithoutXxx opt-out, but production deployments must
// not use those casually.
//
{{- if .Tenant}}
// The router-only skeleton below starts with tenant Redis/cache/idempotency
// already wired. Add messaging modules with the matching adapter Module
// returned by app/amqp.Module / app/nats.Module (registered via
// Builder.With). The Builder composes the middleware chain so adding
// modules does not change router code.
{{- else}}
// The router-only skeleton below mounts a single readiness handler.
// Add Redis / messaging / Postgres adapters by importing the matching
// app/<adapter> sub-package and calling Builder.With(redis.Module(...))
// / .With(amqp.Module(...)) / .With(postgres.Module(...)). The Builder
// composes the middleware chain so adding modules does not change
// router code.
{{- end}}
func Run(_ *slog.Logger, version string) error {
	cfg, err := kitapp.LoadBaseConfig(8080)
	if err != nil {
		return err
	}
{{- if .Tenant}}
	redisFields, err := kitredis.LoadFields()
	if err != nil {
		return err
	}
	redisOpts, err := redisFields.Redis.Options()
	if err != nil {
		return err
	}
{{- end}}

	// ratelimit.IP is required by the Builder's always-on
	// rate-limit gate (Lens F A.5): every service must affirmatively
	// declare a rate-limit policy. Swap to ratelimit.Keyed for
	// API-key throttling, or call WithoutRateLimit when traffic is
	// bounded by mTLS / an upstream gateway. The baseline below is
	// intentionally conservative — tune for the expected QPS once
	// the service ships.
	b := kitapp.New("{{.ServiceName}}", version, cfg).
		With(kitratelimit.IP(100, time.Minute))
{{- if .Postgres}}

	// Postgres + sqlc + goose is the canonical data path. The pgx pool
	// is published on Infrastructure.Resources by app/postgres; access
	// it inside the router via postgres.Pool(infra).
	dsn := config.MustGetSecret("DATABASE_URL", "")
	b = b.
		With(kitpostgres.Module(pgxbackend.Config{DSN: dsn}, kitpostgres.WithMigrations(migrations.FS)))
{{- end}}
{{- if .Tenant}}

	b = b.
		With(kitredisadapter.Module(redisOpts)).
		With(kittenant.Module(httpxtenant.HeaderExtractor("X-Tenant-Id")))
{{- end}}

	return b.
		Router(func(infra kitapp.Infrastructure) http.Handler {
{{- if .Tenant}}
			tenantDeps, err := newTenantResources(kitredisadapter.Connection(infra))
			if err != nil {
				panic("tenant resources: " + err.Error())
			}
{{- end}}
			mux := http.NewServeMux()
{{- if not .Tenant}}
			mux.HandleFunc("/healthz", func(w http.ResponseWriter, _ *http.Request) {
				w.WriteHeader(http.StatusOK)
			})
{{- end}}
{{- if .MCP}}

			// Mount the MCP JSON-RPC endpoint. Builder.With(jwt.Module /
			// tenant.Module / budget.Module) adds the kit's
			// auth + tenant + budget middleware around the public
			// mux automatically — nothing extra to do here.
			mux.Handle("/mcp", newMCPServer().HTTP())
{{- end}}
{{- if .Tenant}}
			// Route constructors should receive tenantDeps.Cache instead
			// of a raw Redis client so tenant scoping stays centralized.
			_ = tenantDeps.Cache
			return httpidempotency.Middleware(tenantDeps.Idempotency,
				httpidempotency.WithUserExtractor(tenantIDForIdempotency),
				httpidempotency.WithSemanticHeaders("X-Tenant-Id"),
			)(mux)
{{- else}}
			return mux
{{- end}}
		}).
		Run()
}
