.PHONY: build test lint vet doctor{{if .Postgres}} sqlc migrate{{end}}{{if .MCP}} mcp-smoke{{end}}

build:
	go build ./...

test:
	go test -race -timeout=5m ./...

lint:
	go fmt ./...
	go vet ./...

vet:
	go vet ./...

doctor:
	go run github.com/bds421/rho-kit/cmd/kit-doctor/v2@latest .
{{if .Postgres}}
# sqlc regenerates db/sqlc/*.go from the .sql files in db/queries/.
# The generated code is checked in so CI doesn't need sqlc installed.
sqlc:
	go run github.com/sqlc-dev/sqlc/cmd/sqlc@latest generate

# migrate publishes the kit's bundled migrations (idempotency, etc.)
# into db/migrations/ so goose can run them alongside your own.
migrate:
	go run github.com/bds421/rho-kit/cmd/kit-migrate/v2@latest publish --to=./db/migrations
{{end}}{{if .MCP}}
# mcp-smoke POSTs a JSON-RPC tools/list call against a locally-running
# service. Start the service in another terminal first:
#
#     go run ./cmd/{{.ServiceName}}
#
# Then `make mcp-smoke` should print the registered tool catalog.
mcp-smoke:
	@echo "Calling tools/list against http://localhost:8080/mcp ..."
	@curl -sS -X POST http://localhost:8080/mcp \
		-H 'Content-Type: application/json' \
		-H 'Accept: application/json, text/event-stream' \
		-d '{"jsonrpc":"2.0","id":1,"method":"tools/list","params":{}}'
	@echo
{{end}}
